# Copy this file to .env and fill in the values

# From Neon: Project → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Any random string of 32+ characters (used to sign session cookies)
SESSION_SECRET=replace-this-with-a-random-32-plus-character-string

# Set automatically by Railway/Render in production; leave as-is for local dev
NODE_ENV=development
PORT=3000
